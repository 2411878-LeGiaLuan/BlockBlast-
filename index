<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Block Blast Extreme - LG Version</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg: #121212; --grid: #1a1a1a; --border: #333; --glow: #2ecc71;
            /* Hệ màu cho các khối */
            --c1: #3498db; --c2: #9b59b6; --c3: #e67e22; --c4: #f1c40f;
            --font: 'Poppins', sans-serif;
        }
        * { box-sizing: border-box; touch-action: none; user-select: none; }
        body { margin: 0; padding: 20px; background: var(--bg); font-family: var(--font); color: white; height: 100vh; display: flex; flex-direction: column; align-items: center; overflow: hidden; }

        /* GIAO DIỆN CHÍNH */
        header { width: 100%; max-width: 400px; display: flex; justify-content: space-between; align-items: center; margin-bottom: 20px; }
        #score-board { text-align: right; }
        #score { font-size: 32px; font-weight: 800; color: var(--glow); text-shadow: 0 0 10px var(--glow); }

        /* LƯỚI GAME 8x8 */
        #grid-container { 
            position: relative; width: 100%; max-width: 400px; aspect-ratio: 1; 
            background: var(--grid); border-radius: 10px; border: 2px solid var(--border); 
            display: grid; grid-template-columns: repeat(8, 1fr); gap: 4px; padding: 4px; 
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
        }
        .cell { background: rgba(255,255,255,0.03); border-radius: 4px; }
        .cell.over { background: rgba(255,255,255,0.1) !important; }

        /* KHỐI TRÊN LƯỚI */
        .block { 
            border-radius: 4px; transition: transform 0.2s, background 0.2s; 
            box-shadow: inset 0 0 10px rgba(255,255,255,0.2), 0 2px 5px rgba(0,0,0,0.3); 
        }

        /* HIỆU ỨNG BLAST (RĂNG CƯA & RƠI) */
        @keyframes blastCell {
            0% { transform: scale(1); filter: brightness(1); opacity: 1; }
            30% { transform: scale(1.1); filter: brightness(1.5) blur(1px); color: white; }
            100% { transform: scale(0.1) translateY(100px); filter: brightness(2); opacity: 0; }
        }
        .blasting { animation: blastCell 0.6s ease-out forwards; z-index: 10; }

        /* KHO CHỨA KHỐI (DƯỚI CÙNG) */
